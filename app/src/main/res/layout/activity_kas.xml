<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F4F6FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔥 FIX DI SINI -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnTambah"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- HEADER -->
            <LinearLayout
                android:background="@drawable/bg_header"
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <TextView
                    android:text="Saldo Kas"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvSaldo"
                    android:text="Rp 0"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvMasuk"
                        android:text="Rp 0"
                        android:textColor="#00FFAA"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvKeluar"
                        android:text="Rp 0"
                        android:textColor="#FFAAAA"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- FILTER -->
            <LinearLayout
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnSemua"
                    android:text="Semua"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"/>

                <Button
                    android:id="@+id/btnMasuk"
                    android:text="Masuk"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"/>

                <Button
                    android:id="@+id/btnKeluar"
                    android:text="Keluar"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"/>
            </LinearLayout>

            <!-- LIST -->
            <LinearLayout
                android:id="@+id/containerKas"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="80dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- 🔥 FIX TOMBOL + -->
    <ImageView
        android:id="@+id/btnTambah"
        android:src="@android:drawable/ic_input_add"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="#FFC107"
        android:layout_alignParentEnd="true"
        android:layout_above="@id/bottomNav"
        android:layout_margin="16dp"
        android:padding="16dp"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"/>

    <!-- NAVBAR -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>