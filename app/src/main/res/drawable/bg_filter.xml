<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- warna background -->
    <solid android:color="#FFFFFF"/>

    <!-- border -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0"/>

    <!-- rounded -->
    <corners android:radius="12dp"/>

    <!-- padding dalam -->
    <padding
        android:left="8dp"
        android:top="6dp"
        android:right="8dp"
        android:bottom="6dp"/>

</shape>